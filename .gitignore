# Working notes and execution artifacts (never commit)
# Contains: TASKS.md, WORKING-LINES.md, prompts/, progress/, logs/,
# phase-specific runs, HIL captures, architecture snapshots, scratch notes
work/

# Ephemeral scratch from codex / AI-tool runs (rendered TOMLs, captured
# stdout/stderr, source-tarball snapshots). Can be large (60 MB+) and
# is always regenerable. Never commit.
.codex-tmp/

# Deploy / infra plans (contain VPS IPs, SSH targets, nginx paths)
# — internal playbooks, never public
docs/plans/vps-*.md
docs/plans/vps-*-notes.md

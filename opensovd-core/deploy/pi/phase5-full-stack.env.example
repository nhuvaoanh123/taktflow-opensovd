# Copy this file to `phase5-full-stack.env` next to it and fill in the
# placeholders locally. Do not commit the real file.

# Required: explicit Pi SSH target in user@host form.
PI=<pi-user>@<pi-bench-ip>

# Optional: service account if it differs from the SSH login user.
# PI_SERVICE_USER=<pi-service-user>
# PI_SERVICE_GROUP=<pi-service-group>

# Optional: set when deploying the hybrid template so cda_forward points
# at the real CDA host without committing private bench IPs.
# PHASE5_CDA_BASE_URL=http://<laptop-ip>:20002

# Optional: override if the Pi HTTP host differs from the SSH host part.
# PI_HTTP_HOST=<pi-bench-ip>

# Rust build artifacts
**/target/

# Python
**/__pycache__/
*.pyc

# Node
**/node_modules/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Claude Code workstation-specific settings. `settings.json` and
# `settings.local.json` carry absolute paths and per-machine
# permissions (drive letters, Windows usernames, allow-lists scoped
# to this checkout). Claude Code loads them locally; they do not
# belong in the public mirror. `*.lock` files under `.claude/` are
# runtime lock artifacts.
.claude/settings.json
.claude/settings.local.json
.claude/*.lock

# Working notes and execution artifacts (never commit)
# Contains: TASKS.md, WORKING-LINES.md, prompts/, progress/, logs/,
# phase-specific runs, HIL captures, architecture snapshots, scratch notes
work/

# Ephemeral scratch from codex / AI-tool runs (rendered TOMLs, captured
# stdout/stderr, source-tarball snapshots). Can be large (60 MB+) and
# is always regenerable. Never commit.
.codex-tmp/

# Deploy / infra plans (contain VPS IPs, SSH targets, nginx paths)
# — internal playbooks, never public
docs/plans/vps-*.md
docs/plans/vps-*-notes.md

# Claude Code session rules — project-local AI prompt config, not for
# the public mirror. Keep the file locally so Claude Code still loads
# the rules, but don't publish workstation-specific details.
CLAUDE.md

# Mis-nested sibling project checkout. Sometimes a `taktflow-embedded-
# production/` tree lands under this repo by accident (drag-drop, wrong
# cwd on a clone). Never commit that into the OpenSOVD repo.
taktflow-embedded-production/

# Local bench flash readbacks named by ST-Link serial. PC-local probe
# artifacts, never for the public mirror.
tmp-*-readback.bin

# Firmware and POSIX-test build outputs
firmware/**/build/
test/firmware/**/build/

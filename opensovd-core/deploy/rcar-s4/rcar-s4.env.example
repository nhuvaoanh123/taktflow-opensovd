# Copy this file locally, fill the placeholders, and keep the real
# values out of git.

# Required target-host SSH target for later deployment automation.
RCAR_S4_TARGET=<target-user>@<target-host>

# Target install root for the first Linux bring-up.
RCAR_S4_INSTALL_ROOT=/opt/taktflow/rcar-s4

# Target service account used to render the systemd unit templates.
RCAR_S4_SERVICE_USER=<target-service-user>
RCAR_S4_SERVICE_GROUP=<target-service-group>

# `sovd-main` host-local bind for the first board bring-up.
RCAR_S4_SOVD_LISTEN_ADDRESS=127.0.0.1
RCAR_S4_SOVD_LISTEN_PORT=21002

# CAN-to-DoIP proxy defaults for the target host.
RCAR_S4_PROXY_LISTEN_ADDRESS=0.0.0.0
RCAR_S4_PROXY_LISTEN_PORT=13400
RCAR_S4_CAN_INTERFACE=<target-can-interface>

# Optional observer relay defaults.
RCAR_S4_WS_BRIDGE_BIND_ADDR=127.0.0.1:8082
RCAR_S4_WS_BRIDGE_MQTT_URL=mqtt://127.0.0.1:1883

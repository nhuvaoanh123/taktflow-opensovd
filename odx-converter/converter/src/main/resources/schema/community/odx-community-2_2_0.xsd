<?xml version="1.0" encoding="UTF-8"?>
<!--
  SPDX-License-Identifier: Apache-2.0
  SPDX-FileCopyrightText: 2026 Taktflow Systems

  Community ODX 2.2 schema (codegen-complete) - ADR-0008 Phase 2.

  This is a CLEAN-ROOM reimplementation of the subset of the ODX 2.2.0
  data model required to build and run the Eclipse OpenSOVD odx-converter
  without the ASAM/ISO 22901-1 licensed schema. It was authored ONLY from:

    1. the Apache-2.0 converter source (odx-converter/converter/src/main/kotlin/),
       which fixes the generated JAXB class/property surface,
    2. the MIT-licensed odxtools model (external/odxtools/) for real ODX
       element names, cardinalities, enum values and type inheritance,
    3. publicly released ASAM ODX documents (external/asam-public/),
    4. MIT/synthetic ODX instance documents:
       external/odxtools/examples/somersault.pdx and
       odx-converter/converter/src/test/resources/synthetic-odx*/,
    5. the Phase-1 recon notes in this directory (RECON.md, PYTHON_MAPPING.md).

  No ASAM XSD was obtained, opened, or transcribed. See
  PHASE2-REQUIREMENTS.md (same directory) for the per-type provenance
  table and docs/adr/0008-odx-community-xsd-default.md for governance.

  Design notes (load-bearing):
  - ODX instance documents use NO namespace (xsi:noNamespaceSchemaLocation),
    hence no targetNamespace here.
  - ID / ID-REF are plain xs:string attributes; the converter resolves
    links itself (duplicate IDs across files are legal in ODX).
  - Abstract bases (PARAM, DIAG-CODED-TYPE, PARENT-REF, DIAG-COMM,
    DIAG-LAYER, DOP-BASE, ...) are modelled with xs:extension because the
    converter dispatches on xsi:type and instanceof.
  - Inline jaxb:property customizations pin the five collapsed-choice
    property names the converter expects (DIAGCOMMPROXY, ROWWRAPPER,
    DTCPROXY, DIAGVARIABLEPROXY, Rest).
  - Only xs:int / xs:long / xs:double numeric types are used (BigInteger /
    BigDecimal would break the converter's .toUInt() calls).
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:jaxb="https://jakarta.ee/xml/ns/jaxb"
           jaxb:version="3.0">

  <!-- ======================================================== -->
  <!-- Root element                                             -->
  <!-- ======================================================== -->

  <xs:element name="ODX" type="ODX"/>

  <xs:complexType name="ODX">
    <xs:sequence>
      <xs:element name="DIAG-LAYER-CONTAINER" type="DIAG-LAYER-CONTAINER" minOccurs="0"/>
      <xs:element name="COMPARAM-SUBSET" type="COMPARAM-SUBSET" minOccurs="0"/>
      <xs:element name="COMPARAM-SPEC" type="COMPARAM-SPEC" minOccurs="0"/>
      <xs:element name="VEHICLE-INFO-SPEC" type="VEHICLE-INFO-SPEC" minOccurs="0"/>
      <xs:element name="FLASH" type="FLASH" minOccurs="0"/>
      <xs:element name="ECU-CONFIG" type="ECU-CONFIG" minOccurs="0"/>
      <xs:element name="MULTIPLE-ECU-JOB-SPEC" type="MULTIPLE-ECU-JOB-SPEC" minOccurs="0"/>
      <xs:element name="FUNCTION-DICTIONARY" type="FUNCTION-DICTIONARY" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="MODEL-VERSION" type="xs:string"/>
  </xs:complexType>

  <!-- Category roots other than DIAG-LAYER-CONTAINER / COMPARAM-*.
       The converter only reads their SHORT-NAME (ODXCollection.containerKey). -->

  <xs:complexType name="VEHICLE-INFO-SPEC">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
      <xs:element name="ADMIN-DATA" type="ADMIN-DATA" minOccurs="0"/>
      <xs:element name="COMPANY-DATAS" type="COMPANY-DATAS" minOccurs="0"/>
      <xs:element name="SDGS" type="SDGS" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="ID" type="xs:string" use="required"/>
  </xs:complexType>

  <xs:complexType name="FLASH">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
      <xs:element name="ADMIN-DATA" type="ADMIN-DATA" minOccurs="0"/>
      <xs:element name="COMPANY-DATAS" type="COMPANY-DATAS" minOccurs="0"/>
      <xs:element name="SDGS" type="SDGS" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="ID" type="xs:string" use="required"/>
  </xs:complexType>

  <xs:complexType name="ECU-CONFIG">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
      <xs:element name="ADMIN-DATA" type="ADMIN-DATA" minOccurs="0"/>
      <xs:element name="COMPANY-DATAS" type="COMPANY-DATAS" minOccurs="0"/>
      <xs:element name="SDGS" type="SDGS" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="ID" type="xs:string" use="required"/>
  </xs:complexType>

  <xs:complexType name="MULTIPLE-ECU-JOB-SPEC">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
      <xs:element name="ADMIN-DATA" type="ADMIN-DATA" minOccurs="0"/>
      <xs:element name="COMPANY-DATAS" type="COMPANY-DATAS" minOccurs="0"/>
      <xs:element name="SDGS" type="SDGS" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="ID" type="xs:string" use="required"/>
  </xs:complexType>

  <xs:complexType name="FUNCTION-DICTIONARY">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
      <xs:element name="ADMIN-DATA" type="ADMIN-DATA" minOccurs="0"/>
      <xs:element name="COMPANY-DATAS" type="COMPANY-DATAS" minOccurs="0"/>
      <xs:element name="SDGS" type="SDGS" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="ID" type="xs:string" use="required"/>
  </xs:complexType>

  <!-- ======================================================== -->
  <!-- Enumerations                                             -->
  <!-- ======================================================== -->

  <xs:simpleType name="ADDRESSING">
    <xs:restriction base="xs:string">
      <xs:enumeration value="FUNCTIONAL"/>
      <xs:enumeration value="PHYSICAL"/>
      <xs:enumeration value="FUNCTIONAL-OR-PHYSICAL"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="TRANS-MODE">
    <xs:restriction base="xs:string">
      <xs:enumeration value="SEND-ONLY"/>
      <xs:enumeration value="RECEIVE-ONLY"/>
      <xs:enumeration value="SEND-AND-RECEIVE"/>
      <xs:enumeration value="SEND-OR-RECEIVE"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="DIAG-CLASS-TYPE">
    <xs:restriction base="xs:string">
      <xs:enumeration value="STARTCOMM"/>
      <xs:enumeration value="STOPCOMM"/>
      <xs:enumeration value="VARIANTIDENTIFICATION"/>
      <xs:enumeration value="READ-DYN-DEF-MESSAGE"/>
      <xs:enumeration value="DYN-DEF-MESSAGE"/>
      <xs:enumeration value="CLEAR-DYN-DEF-MESSAGE"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="INTERVAL-TYPE">
    <xs:restriction base="xs:string">
      <xs:enumeration value="OPEN"/>
      <xs:enumeration value="CLOSED"/>
      <xs:enumeration value="INFINITE"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="COMPU-CATEGORY">
    <xs:restriction base="xs:string">
      <xs:enumeration value="IDENTICAL"/>
      <xs:enumeration value="LINEAR"/>
      <xs:enumeration value="SCALE-LINEAR"/>
      <xs:enumeration value="TEXTTABLE"/>
      <xs:enumeration value="COMPUCODE"/>
      <xs:enumeration value="TAB-INTP"/>
      <xs:enumeration value="RAT-FUNC"/>
      <xs:enumeration value="SCALE-RAT-FUNC"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="DATA-TYPE">
    <xs:restriction base="xs:string">
      <xs:enumeration value="A_INT32"/>
      <xs:enumeration value="A_UINT32"/>
      <xs:enumeration value="A_FLOAT32"/>
      <xs:enumeration value="A_FLOAT64"/>
      <xs:enumeration value="A_ASCIISTRING"/>
      <xs:enumeration value="A_UTF8STRING"/>
      <xs:enumeration value="A_UNICODE2STRING"/>
      <xs:enumeration value="A_BYTEFIELD"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="PHYSICAL-DATA-TYPE">
    <xs:restriction base="xs:string">
      <xs:enumeration value="A_INT32"/>
      <xs:enumeration value="A_UINT32"/>
      <xs:enumeration value="A_FLOAT32"/>
      <xs:enumeration value="A_FLOAT64"/>
      <xs:enumeration value="A_BYTEFIELD"/>
      <xs:enumeration value="A_UNICODE2STRING"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="RADIX">
    <xs:restriction base="xs:string">
      <xs:enumeration value="HEX"/>
      <xs:enumeration value="DEC"/>
      <xs:enumeration value="BIN"/>
      <xs:enumeration value="OCT"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="TERMINATION">
    <xs:restriction base="xs:string">
      <xs:enumeration value="END-OF-PDU"/>
      <xs:enumeration value="ZERO"/>
      <xs:enumeration value="HEX-FF"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="STANDARDISATION-LEVEL">
    <xs:restriction base="xs:string">
      <xs:enumeration value="STANDARD"/>
      <xs:enumeration value="OEM-SPECIFIC"/>
      <xs:enumeration value="OPTIONAL"/>
      <xs:enumeration value="OEM-OPTIONAL"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="USAGE">
    <xs:restriction base="xs:string">
      <xs:enumeration value="ECU-SOFTWARE"/>
      <xs:enumeration value="ECU-COMM"/>
      <xs:enumeration value="APPLICATION"/>
      <xs:enumeration value="TESTER"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="ROW-FRAGMENT">
    <xs:restriction base="xs:string">
      <xs:enumeration value="KEY"/>
      <xs:enumeration value="STRUCT"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="VALID-TYPE">
    <xs:restriction base="xs:string">
      <xs:enumeration value="VALID"/>
      <xs:enumeration value="NOT-VALID"/>
      <xs:enumeration value="NOT-DEFINED"/>
      <xs:enumeration value="NOT-AVAILABLE"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="DOCTYPE">
    <xs:restriction base="xs:string">
      <xs:enumeration value="FLASH"/>
      <xs:enumeration value="CONTAINER"/>
      <xs:enumeration value="LAYER"/>
      <xs:enumeration value="MULTIPLE-ECU-JOB-SPEC"/>
      <xs:enumeration value="COMPARAM-SPEC"/>
      <xs:enumeration value="VEHICLE-INFO-SPEC"/>
      <xs:enumeration value="COMPARAM-SUBSET"/>
      <xs:enumeration value="ECU-CONFIG"/>
      <xs:enumeration value="FUNCTION-DICTIONARY-SPEC"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ======================================================== -->
  <!-- Reference and text primitives                            -->
  <!-- ======================================================== -->

  <xs:complexType name="ODXLINK">
    <xs:attribute name="ID-REF" type="xs:string" use="required"/>
    <xs:attribute name="DOCREF" type="xs:string"/>
    <xs:attribute name="DOCTYPE" type="DOCTYPE"/>
    <xs:attribute name="REVISION" type="xs:string"/>
  </xs:complexType>

  <xs:complexType name="SNREF">
    <xs:attribute name="SHORT-NAME" type="xs:string" use="required"/>
  </xs:complexType>

  <xs:complexType name="SNPATHREF">
    <xs:attribute name="SHORT-NAME-PATH" type="xs:string" use="required"/>
  </xs:complexType>

  <xs:complexType name="LONG-NAME">
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="TI" type="xs:string"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="TEXT">
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="TI" type="xs:string"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="DESCRIPTION" mixed="true">
    <xs:sequence>
      <xs:any processContents="skip" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="LIMIT">
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="INTERVAL-TYPE" type="INTERVAL-TYPE"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <!-- ======================================================== -->
  <!-- Special data (SDGS)                                      -->
  <!-- ======================================================== -->

  <xs:complexType name="SD">
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="SI" type="xs:string"/>
        <xs:attribute name="TI" type="xs:string"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="SDG-CAPTION">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="ID" type="xs:string" use="required"/>
  </xs:complexType>

  <xs:complexType name="SDG">
    <xs:sequence>
      <xs:element name="SDG-CAPTION" type="SDG-CAPTION" minOccurs="0"/>
      <xs:element name="SDG-CAPTION-REF" type="ODXLINK" minOccurs="0"/>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element name="SDG" type="SDG"/>
        <xs:element name="SD" type="SD"/>
      </xs:choice>
    </xs:sequence>
    <xs:attribute name="SI" type="xs:string"/>
  </xs:complexType>

  <xs:complexType name="SDGS">
    <xs:sequence>
      <xs:element name="SDG" type="SDG" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <!-- ======================================================== -->
  <!-- Administrative / company data                            -->
  <!-- ======================================================== -->

  <xs:complexType name="ADMIN-DATA">
    <xs:sequence>
      <xs:element name="LANGUAGE" type="xs:string" minOccurs="0"/>
      <xs:element name="COMPANY-DOC-INFOS" type="COMPANY-DOC-INFOS" minOccurs="0"/>
      <xs:element name="DOC-REVISIONS" type="DOC-REVISIONS" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="COMPANY-DOC-INFOS">
    <xs:sequence>
      <xs:element name="COMPANY-DOC-INFO" type="COMPANY-DOC-INFO" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="COMPANY-DOC-INFO">
    <xs:sequence>
      <xs:element name="COMPANY-DATA-REF" type="ODXLINK"/>
      <xs:element name="TEAM-MEMBER-REF" type="ODXLINK" minOccurs="0"/>
      <xs:element name="DOC-LABEL" type="xs:string" minOccurs="0"/>
      <xs:element name="SDGS" type="SDGS" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DOC-REVISIONS">
    <xs:sequence>
      <xs:element name="DOC-REVISION" type="DOC-REVISION" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DOC-REVISION">
    <xs:sequence>
      <xs:element name="TEAM-MEMBER-REF" type="ODXLINK" minOccurs="0"/>
      <xs:element name="REVISION-LABEL" type="xs:string" minOccurs="0"/>
      <xs:element name="STATE" type="xs:string" minOccurs="0"/>
      <xs:element name="DATE" type="xs:string"/>
      <xs:element name="TOOL" type="xs:string" minOccurs="0"/>
      <xs:element name="COMPANY-REVISION-INFOS" type="COMPANY-REVISION-INFOS" minOccurs="0"/>
      <xs:element name="MODIFICATIONS" type="MODIFICATIONS" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="COMPANY-REVISION-INFOS">
    <xs:sequence>
      <xs:element name="COMPANY-REVISION-INFO" type="COMPANY-REVISION-INFO" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="COMPANY-REVISION-INFO">
    <xs:sequence>
      <xs:element name="COMPANY-DATA-REF" type="ODXLINK"/>
      <xs:element name="REVISION-LABEL" type="xs:string" minOccurs="0"/>
      <xs:element name="STATE" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="MODIFICATIONS">
    <xs:sequence>
      <xs:element name="MODIFICATION" type="MODIFICATION" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="MODIFICATION">
    <xs:sequence>
      <xs:element name="CHANGE" type="xs:string" minOccurs="0"/>
      <xs:element name="REASON" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="COMPANY-DATAS">
    <xs:sequence>
      <xs:element name="COMPANY-DATA" type="COMPANY-DATA" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="COMPANY-DATA">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
      <xs:element name="ROLES" type="ROLES" minOccurs="0"/>
      <xs:element name="TEAM-MEMBERS" type="TEAM-MEMBERS" minOccurs="0"/>
      <xs:element name="COMPANY-SPECIFIC-INFO" type="COMPANY-SPECIFIC-INFO" minOccurs="0"/>
      <xs:element name="SDGS" type="SDGS" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="ID" type="xs:string" use="required"/>
  </xs:complexType>

  <xs:complexType name="ROLES">
    <xs:sequence>
      <xs:element name="ROLE" type="xs:string" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="TEAM-MEMBERS">
    <xs:sequence>
      <xs:element name="TEAM-MEMBER" type="TEAM-MEMBER" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="TEAM-MEMBER">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
      <xs:element name="ROLES" type="ROLES" minOccurs="0"/>
      <xs:element name="DEPARTMENT" type="xs:string" minOccurs="0"/>
      <xs:element name="ADDRESS" type="xs:string" minOccurs="0"/>
      <xs:element name="ZIP" type="xs:string" minOccurs="0"/>
      <xs:element name="CITY" type="xs:string" minOccurs="0"/>
      <xs:element name="PHONE" type="xs:string" minOccurs="0"/>
      <xs:element name="FAX" type="xs:string" minOccurs="0"/>
      <xs:element name="EMAIL" type="xs:string" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="ID" type="xs:string" use="required"/>
  </xs:complexType>

  <xs:complexType name="COMPANY-SPECIFIC-INFO">
    <xs:sequence>
      <xs:element name="RELATED-DOCS" type="RELATED-DOCS" minOccurs="0"/>
      <xs:element name="SDGS" type="SDGS" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="RELATED-DOCS">
    <xs:sequence>
      <xs:element name="RELATED-DOC" type="RELATED-DOC" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="RELATED-DOC">
    <xs:sequence>
      <xs:element name="XDOC" type="XDOC" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="XDOC">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
      <xs:element name="NUMBER" type="xs:string" minOccurs="0"/>
      <xs:element name="STATE" type="xs:string" minOccurs="0"/>
      <xs:element name="DATE" type="xs:string" minOccurs="0"/>
      <xs:element name="PUBLISHER" type="xs:string" minOccurs="0"/>
      <xs:element name="URL" type="xs:string" minOccurs="0"/>
      <xs:element name="POSITION" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <!-- ======================================================== -->
  <!-- Diagnostic layer container and layers                    -->
  <!-- ======================================================== -->

  <xs:complexType name="DIAG-LAYER-CONTAINER">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
      <xs:element name="ADMIN-DATA" type="ADMIN-DATA" minOccurs="0"/>
      <xs:element name="COMPANY-DATAS" type="COMPANY-DATAS" minOccurs="0"/>
      <xs:element name="ECU-SHARED-DATAS" type="ECU-SHARED-DATAS" minOccurs="0"/>
      <xs:element name="PROTOCOLS" type="PROTOCOLS" minOccurs="0"/>
      <xs:element name="FUNCTIONAL-GROUPS" type="FUNCTIONAL-GROUPS" minOccurs="0"/>
      <xs:element name="BASE-VARIANTS" type="BASE-VARIANTS" minOccurs="0"/>
      <xs:element name="ECU-VARIANTS" type="ECU-VARIANTS" minOccurs="0"/>
      <xs:element name="SDGS" type="SDGS" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="ID" type="xs:string" use="required"/>
  </xs:complexType>

  <xs:complexType name="ECU-SHARED-DATAS">
    <xs:sequence>
      <xs:element name="ECU-SHARED-DATA" type="ECU-SHARED-DATA" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PROTOCOLS">
    <xs:sequence>
      <xs:element name="PROTOCOL" type="PROTOCOL" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="FUNCTIONAL-GROUPS">
    <xs:sequence>
      <xs:element name="FUNCTIONAL-GROUP" type="FUNCTIONAL-GROUP" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="BASE-VARIANTS">
    <xs:sequence>
      <xs:element name="BASE-VARIANT" type="BASE-VARIANT" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ECU-VARIANTS">
    <xs:sequence>
      <xs:element name="ECU-VARIANT" type="ECU-VARIANT" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DIAG-LAYER" abstract="true">
    <xs:sequence>
      <xs:element name="SHORT-NAME" type="xs:string"/>
      <xs:element name="LONG-NAME" type="LONG-NAME" minOccurs="0"/>
      <xs:element name="DESC" type="DESCRIPTION" minOccurs="0"/>
      <xs:element name="ADMIN-DATA" type="ADMIN-DATA" minOccurs="0"/>
      <xs:element name="COMPANY-DATAS" type="COMPANY-DATAS" minOccurs="0"/>
      <xs:element name="FUNCT-CLASSS" type="FUNCT-CLASSS" minOccurs="0"/>
      <xs:element name="DIAG-DATA-DICTIONARY-SPEC" type="DIAG-DATA-DICTIONARY-SPEC" minOccurs="0"/>
